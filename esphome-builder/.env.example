# ESPHome Builder — connection settings
# ---------------------------------------------------------------------------
# Copy this file to `.env` in your working dir (or to
# ~/.config/esphome-builder/.env), fill in the values, then:  chmod 600 .env
# and add `.env` to your .gitignore. NEVER commit a real .env.
#
# The agent does not need to handle the password: you populate it here, and the
# tool reads it from the environment. These are Builder *login* credentials —
# separate from device !secret values, which stay in the Builder's secrets.yaml.
# ---------------------------------------------------------------------------

# Preferred (when ESPHome runs as a Home Assistant add-on): HA ingress.
# The tool creates an ingress session over Home Assistant's websocket API, then
# calls /api/hassio_ingress/<token>/... with Cookie: ingress_session=<session>.
ESPHOME_HA_URL=http://homeassistant.local:8123
ESPHOME_HA_TOKEN=
ESPHOME_HA_ADDON_SLUG=5c53de3b_esphome
# For the newer beta add-on, use: 5c53de3b_esphome-beta

# Direct fallback: where the ESPHome Builder is reachable (http or https, host[:port]).
# This is tried after HA ingress if both are configured and ingress fails.
ESPHOME_DASHBOARD_URL=http://HOST:6052

# Optional: dashboard auth. Leave blank if the Builder has no auth
# (e.g. HA add-on ingress or the "leave_front_door_open" option).
ESPHOME_DASHBOARD_USERNAME=
ESPHOME_DASHBOARD_PASSWORD=

# Optional: set to true only for a self-signed TLS certificate.
ESPHOME_DASHBOARD_INSECURE=false

# Optional: default output locations.
ESPHOME_BACKUP_DIR=./esphome-backup
# ESPHOME_BUILDER_LOG_DIR=~/.cache/esphome-builder/logs

# Note: ESPHOME_TRUSTED_DOMAINS (for WebSocket origin checks behind a proxy) is
# configured on the Builder host itself, not in this file.
